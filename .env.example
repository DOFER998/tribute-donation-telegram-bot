# Образ бота (опц., по умолчанию ghcr.io/dofer998/tribute-donation-telegram-bot:latest)
# BOT_IMAGE=ghcr.io/dofer998/tribute-donation-telegram-bot:latest

# Telegram bot
BOT__TOKEN=

# Публичный домен с HTTPS, на который Telegram + Tribute шлют вебхуки
APP__DOMAIN=
APP__SECRET_TOKEN=

# Пароли для Postgres и Redis (генерируй случайные)
POSTGRES__PASSWORD=
REDIS__PASSWORD=

# Tribute
TRIBUTE__API_KEY=
TRIBUTE__DONATE_LINK=https://tribute.tg/...
TRIBUTE__ALERT_GROUP_ID=

# Telegram user-id'ы админов (JSON-список)
ADMIN__IDS=[]

# --- опциональное (есть дефолты в коде) ---
# APP__HOST=0.0.0.0
# APP__PORT=9090
# APP__DEBUG=false
# POSTGRES__HOST=postgres
# POSTGRES__PORT=5432
# POSTGRES__USER=fundraiser
# POSTGRES__DATABASE=fundraiser_bot
# REDIS__HOST=redis
# REDIS__PORT=6379
# REDIS__NAME=0
# DIGEST__HOUR=21
